generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  EXTERNO
  INVITADO
  ADMINISTRADOR
}

enum EstadoEvento {
  ACTIVO
  COMPLETADO
  CANCELADO
}

model Evento {
  id          Int          @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float
  urlImagen   String?
  fecha       DateTime
  estado      EstadoEvento @default(ACTIVO)
  categoriaId Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  categoria   Categoria?   @relation(fields: [categoriaId], references: [id])

  interesados    UsuarioInteresado[]
  eventoEntradas EventoEntrada[]
}

model Categoria {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  eventos Evento[]
}

model Usuario {
  id        Int           @id @default(autoincrement())
  nombre    String
  apellido  String?
  correo    String?       @unique
  username  String        @unique
  password  String
  tipo      TipoUsuario
  createdAt DateTime      @default(now())

  intereses UsuarioInteresado[]
  ventas    Venta[]
}

model UsuarioInteresado {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  eventoId  Int
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  evento  Evento  @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, eventoId])
}

model CategoriaEntrada {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  eventoEntradas EventoEntrada[]
}

model EventoEntrada {
  id                  Int      @id @default(autoincrement())
  eventoId            Int
  categoriaEntradaId  Int
  cantidadTotal       Int
  cantidadDisponible  Int
  precio              Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  evento           Evento           @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  categoriaEntrada CategoriaEntrada @relation(fields: [categoriaEntradaId], references: [id])

  detallesBoleta DetalleBoleta[]

  @@unique([eventoId, categoriaEntradaId])
}

model Venta {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  codigoQR   String   @unique @default(uuid())
  total      Float
  fechaVenta DateTime @default(now())
  createdAt  DateTime @default(now())

  usuario  Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  detalles DetalleBoleta[]
}

model DetalleBoleta {
  id               Int      @id @default(autoincrement())
  ventaId          Int
  eventoEntradaId  Int
  cantidad         Int
  precioUnitario   Float
  subtotal         Float
  createdAt        DateTime @default(now())

  venta         Venta         @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  eventoEntrada EventoEntrada @relation(fields: [eventoEntradaId], references: [id])
}
